# ============================================
# WEDDING INVITATION APP - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!

# ============================================
# FRONTEND CONFIGURATION (VITE)
# ============================================
# These variables are embedded into the frontend at BUILD TIME

# Wedding Date (ISO 8601 format)
VITE_APP_WEDDING_DATE=2026-04-11T17:00:00

# Wedding Event Times
VITE_WEDDING_AKAD_TIME=08.00 - 10.00 WIB
VITE_WEDDING_RESEPSI_TIME=11.00 - 13.00 WIB

# Wedding Venue Details
VITE_WEDDING_VENUE=Your Venue Name
VITE_WEDDING_DETAIL=Venue address or additional details
VITE_VENUE_MAPS_URL=https://maps.google.com/your-venue-link

# Couple Names (Full)
VITE_BRIDE_NAME=Bride Full Name
VITE_GROOM_NAME=Groom Full Name

# Couple Names (short - for splash/thank you sections)
VITE_BRIDE_SHORT_NAME=Bride
VITE_GROOM_SHORT_NAME=Groom

# Couple Parents
VITE_BRIDE_FATHER=Bride's Father Name
VITE_BRIDE_MOTHER=Bride's Mother Name
VITE_GROOM_FATHER=Groom's Father Name
VITE_GROOM_MOTHER=Groom's Mother Name

# Gift Banking Details (Partner 1)
VITE_PARTNER1_BANK_NAME=Bank Name
VITE_PARTNER1_ACCOUNT_NAME="Partner 1 Full Name"
VITE_PARTNER1_ACCOUNT_NUMBER="1234567890"

# Gift Banking Details (Partner 2)
VITE_PARTNER2_BANK_NAME=Bank Name
VITE_PARTNER2_ACCOUNT_NAME="Partner 2 Full Name"
VITE_PARTNER2_ACCOUNT_NUMBER="0987654321"

# YouTube Playlist URL (optional)
# Example: RDQMgEzdN5RuCXE
VITE_YOUTUBE_PLAYLIST_URL=

# Photo Gallery JSON URL or path (optional)
VITE_PHOTOS_JSON=

# Gallery Toggle
# Set to 'true' to disable photo gallery and show placeholder silhouettes
# Default: false (gallery enabled)
VITE_DISABLE_GALLERY=false

# ============================================
# BACKEND CONFIGURATION (Go)
# ============================================
# These variables are loaded at RUNTIME

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=86400

# Admin API Key (for management endpoints)
# Generate a secure random key: openssl rand -hex 32
ADMIN_API_KEY=your-admin-api-key-change-this

# Database Configuration
DB_PATH=data/guests.db

# Server Configuration
SERVER_PORT=:8080

# Cache Configuration (duration format: s, m, h)
CACHE_GUEST_TTL=5m
CACHE_COMMENT_TTL=2m

# Rate Limiting Configuration
# Auth endpoints (login, validate)
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=1m

# RSVP endpoints
RATE_LIMIT_RSVP_MAX=10
RATE_LIMIT_RSVP_WINDOW=1m

# Comment endpoints
RATE_LIMIT_COMMENT_MAX=5
RATE_LIMIT_COMMENT_WINDOW=1m

# Business Logic
MAX_COMMENTS_PER_GUEST=2

# ============================================
# SPOTIFY INTEGRATION (Optional - Currently Disabled)
# ============================================
# Get credentials from: https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8080/spotify/callback
SPOTIFY_CACHE_SECONDS=300

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
# Required for production deployment with Traefik

# Your domain name (without http/https or www)
# Example: yourwedding.com
DOMAIN=example.com

# Email for Let's Encrypt SSL certificates
# This email receives expiry notifications
LETSENCRYPT_EMAIL=your-email@example.com

# ============================================
# SECURITY NOTES
# ============================================
# 1. Generate strong JWT_SECRET: openssl rand -base64 32
# 2. Generate strong ADMIN_API_KEY: openssl rand -hex 32
# 3. Never commit .env file to git
# 4. Use different credentials for development vs production
# 5. Regularly rotate secrets
